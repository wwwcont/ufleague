APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=10s

LOG_LEVEL=info
LOG_FORMAT=json

DATABASE_URL=postgres://postgres:postgres@postgres:5432/football_ui?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_CONNECT_TIMEOUT=5s
DB_HEALTHCHECK_PERIOD=30s

SESSION_COOKIE_NAME=football_session
SESSION_TTL=24h
SESSION_SECURE=false
SESSION_DOMAIN=

## Security (production: configure explicit public origins and trusted proxy CIDRs)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUSTED_PROXIES=127.0.0.1/32,::1/128
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_PER_MINUTE=240

DEV_LOGIN_ENABLED=true
TELEGRAM_MOCK_LOGIN_ENABLED=true
TELEGRAM_MOCK_CODE=UFL-SUPERADMIN-2026
COMMENTS_COOLDOWN=3s
TELEGRAM_MINIAPP_AUTH_URL=https://example.com/tg-auth
TELEGRAM_BOT_TOKEN=
