APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_SHUTDOWN_TIMEOUT=10s

LOG_LEVEL=info
LOG_FORMAT=json

DATABASE_URL=postgres://postgres:postgres@postgres:5432/football_ui?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_CONNECT_TIMEOUT=5s
DB_HEALTHCHECK_PERIOD=30s

SESSION_COOKIE_NAME=football_session
SESSION_TTL=24h
SESSION_SECURE=false
SESSION_DOMAIN=

DEV_LOGIN_ENABLED=true
COMMENTS_COOLDOWN=3s
TELEGRAM_MINIAPP_AUTH_URL=https://example.com/tg-auth
TELEGRAM_BOT_TOKEN=
